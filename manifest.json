{
  "manifest_version": 3,
  "name": "FleetCommand",
  "version": "1.2.0",
  "description": "Enterprise-grade printer monitoring and workflow accelerator.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open FleetCommand"
  },
  "permissions": [
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "developer@airbasek4.nl",
      "strict_min_version": "109.0"
    }
  }
}